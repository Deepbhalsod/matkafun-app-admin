    <!-- Bank / Withdraw Method button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/button"
        android:gravity="center"
        android:backgroundTint="@color/adarkg"
        android:layout_marginHorizontal="20dp">
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bankBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            android:layout_weight="1">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="5dp"
                android:background="@color/alightg"
                android:layout_gravity="center"
                android:gravity="center">
                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/bank1"
                    android:tint="@color/white"
                    android:layout_marginTop="8dp"
                    android:layout_margin="5dp"/>
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/withdraw_method"
                    android:layout_marginBottom="8dp"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:fontFamily="@font/font2"
                    android:gravity="center"
                    android:textColor="@color/white"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
    <RelativeLayout
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvFundHistoryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fund Transaction History"
            android:textColor="@color/btnTextColor"
            android:textStyle="bold"
            android:fontFamily="@font/font2"
            android:textSize="16sp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvFundHistoryTitle"
            android:layout_marginHorizontal="20dp"
            android:id="@+id/recyclerViewWallet"
            tools:listitem="@layout/purse_layout"/>
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/emptyImage"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_centerInParent="true"
            app:tint="@color/white"
            android:src="@drawable/baseline_history_24"
            android:layout_marginVertical="100dp"
            android:visibility="gone"/>
    </RelativeLayout>



</LinearLayout>