<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/primary_color"
    tools:context=".sfdghj.SignInActivity">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/dataConText"
        android:text="@string/you_are_not_connected_to_internet"
        android:textColor="@color/black"
        android:background="@color/warn_red"
        android:padding="10dp"
        android:visibility="gone"
        android:elevation="1dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:background="@drawable/logr"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/imageview1"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:scaleType="fitCenter"
                android:src="@drawable/appicon" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_horizontal"
                android:background="@drawable/loginr1"
                android:orientation="vertical"
                android:padding="15dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginHorizontal="0dp"
                    android:fontFamily="@font/font2"
                    android:text="Login"
                    android:textColor="@color/btnTextColor"
                    android:textSize="30sp" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginHorizontal="0dp"
                    android:text="Sign in your account"
                    android:textColor="@color/alcolor"
                    android:textSize="16sp" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/phone_num"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font3"
                    android:layout_marginVertical="10dp"
                    android:background="@drawable/edittext_outline"
                    android:drawableStart="@drawable/baseline_phone_iphone_24"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/alcolor"
                    android:hint="Phone"
                    android:inputType="number"
                    android:maxLength="10"
                    android:paddingHorizontal="30dp"
                    android:paddingVertical="12dp"
                    android:singleLine="true"
                    android:textColor="@color/alcolor"
                    android:textColorHint="@color/alcolor"
                    android:textCursorDrawable="@drawable/ic_cursor"
                    android:textStyle="bold"
                    tools:targetApi="m" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/in_pass"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edittext_outline"
                        android:fontFamily="@font/font3"
                        android:drawableStart="@drawable/ic_lock_icon_01"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/alcolor"
                        android:hint="@string/pass"
                        android:textColorHint="@color/alcolor"
                        android:importantForAutofill="no"
                        android:inputType="textPassword"
                        android:paddingHorizontal="30dp"
                        android:paddingVertical="12dp"
                        android:singleLine="true"
                        android:textColor="@color/alcolor"
                        android:textCursorDrawable="@drawable/ic_cursor"
                        android:textStyle="bold"
                        tools:targetApi="m" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/pass_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_baseline_visibility_24"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:tint="@color/alcolor"
                        android:layout_marginHorizontal="20dp"
                        android:onClick="passToggle"/>
                </RelativeLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:visibility="visible"
                    android:layout_marginEnd="0dp"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="@font/font2"
                    android:onClick="forPass"
                    android:padding="10dp"
                    android:text="@string/forgot_pass"
                    android:textColor="@color/btnTextColor"
                    android:textSize="15sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:backgroundTint="@color/adarkg"
                android:fontFamily="@font/font2"
                android:onClick="SignInBtn"
                android:paddingVertical="10dp"
                android:text="LOGIN"
                android:textAllCaps="false"
                android:textColor="@color/alcolor1"
                android:textSize="18sp"
                app:cornerRadius="20dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="30dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textStyle="bold"
                    android:fontFamily="@font/font3"
                    android:onClick="registerClick"
                    android:padding="0dp"
                    android:text="@string/no_account"
                    android:textColor="@color/adarkg"
                    android:textSize="17sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="0dp"
                    android:fontFamily="@font/font4"
                    android:visibility="gone"
                    android:text="Have trouble login in?"
                    android:textSize="18sp"
                    android:textColor="@color/adarkg" />

                <LinearLayout
                    android:id="@+id/contact_us_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:visibility="visible"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/wp_icon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/whatsapp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:fontFamily="@font/font4"
                        android:padding="0dp"
                        android:textStyle="bold"
                        android:text="Contact us"
                        android:visibility="visible"
                        android:textColor="@color/adarkg"
                        android:textSize="18sp" />
                </LinearLayout>


            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:id="@+id/progressBar"
        android:indeterminateTint="@color/editTextColor"
        android:visibility="gone"/>

</RelativeLayout>
