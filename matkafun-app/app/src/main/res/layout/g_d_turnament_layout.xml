<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="10dp"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="5dp">
    <RelativeLayout
        android:layout_margin="1dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/topReLayt"
                android:background="@color/white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <com.romainpiel.shimmer.ShimmerTextView
                    android:id="@+id/gameName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:elevation="1dp"
                    android:fontFamily="@font/font1"
                    android:gravity="start"
                    android:letterSpacing="0.1"
                    android:text="Milan Live"
                    android:textAllCaps="true"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:ignore="RelativeOverlap" />
            </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/topReLayt"
            android:background="@color/white"
            android:padding="12dp">

            <com.romainpiel.shimmer.ShimmerTextView
                android:id="@+id/marketOpen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:fontFamily="@font/font2"
                android:text="Market closed for today"
                android:textColor="@color/adarkg"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/gameResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/marketOpen"
                android:letterSpacing="0.4"
                android:text="12345677"
                android:layout_marginHorizontal="40dp"
                android:fontFamily="@font/font2"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/closeTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/gameResult"
                android:layout_alignParentStart="true"
                android:layout_marginStart="5dp"
                android:fontFamily="@font/font3"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="5dp"
                android:layout_marginBottom="5dp"
                android:drawableStart="@drawable/ic_clock_svgrepo_com"
                android:drawablePadding="3dp"
                android:gravity="center"
                android:text="Close: 10:30 AM"
                android:textColor="@color/white" />
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/gamePlay"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/play_icon"
                android:layout_alignParentEnd="true"
                android:tint="@color/white"
                android:layout_centerVertical="true"
                android:layout_marginEnd="15dp"
                android:background="@drawable/circle_red"
                android:padding="10dp"/>
        </RelativeLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>