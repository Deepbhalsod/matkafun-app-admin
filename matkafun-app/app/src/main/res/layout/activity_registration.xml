<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_color"
    tools:context=".sfdghj.RegistrationActivity">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/dataConText"
        android:text="@string/you_are_not_connected_to_internet"
        android:textColor="@color/black"
        android:background="@color/warn_red"
        android:padding="5dp"
        android:visibility="gone"
        android:elevation="1dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:background="@drawable/logr"
            android:orientation="vertical"
            android:padding="20dp">


            <ImageView
                android:id="@+id/imageview1"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginBottom="10dp"
                android:src="@drawable/appicon"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:gravity="center_horizontal"
                android:background="@drawable/loginr1"
                android:orientation="vertical"
                android:padding="15dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginHorizontal="0dp"
                    android:text="Registration"
                    android:fontFamily="@font/font2"
                    android:textColor="@color/btnTextColor"
                    android:textSize="20sp" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginHorizontal="0dp"
                    android:text="Sign up your account"
                    android:textColor="@color/alcolor"
                    android:textSize="16sp" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/user_name"
                    android:layout_width="match_parent"
                    android:fontFamily="@font/font3"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="10dp"
                    android:background="@drawable/edittext_outline"
                    android:drawableStart="@drawable/ic_profile_icon_01"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/alcolor"
                    android:hint="Name"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingHorizontal="30dp"
                    android:paddingVertical="12dp"
                    android:singleLine="true"
                    android:textColor="@color/alcolor"
                    android:textColorHint="@color/alcolor"
                    android:textCursorDrawable="@drawable/ic_cursor"
                    android:textStyle="bold"
                    tools:targetApi="m" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/phone_num"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font3"
                    android:layout_marginVertical="10dp"
                    android:background="@drawable/edittext_outline"
                    android:drawableStart="@drawable/ic_phone_icon_01"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/alcolor"
                    android:hint="Phone"
                    android:inputType="number"
                    android:maxLength="10"
                    android:paddingHorizontal="30dp"
                    android:paddingVertical="12dp"
                    android:singleLine="true"
                    android:textColor="@color/alcolor"
                    android:textColorHint="@color/alcolor"
                    android:textCursorDrawable="@drawable/ic_cursor"
                    android:textStyle="bold"
                    tools:targetApi="m" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/in_pass"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font3"
                        android:background="@drawable/edittext_outline"
                        android:drawableStart="@drawable/ic_lock_icon_01"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/alcolor"
                        android:hint="@string/pass"
                        android:inputType="textWebPassword"
                        android:maxLength="18"
                        android:paddingHorizontal="30dp"
                        android:paddingVertical="12dp"
                        android:singleLine="true"
                        android:textColor="@color/alcolor"
                        android:textColorHint="@color/alcolor"
                        android:textCursorDrawable="@drawable/ic_cursor"
                        android:textStyle="bold"
                        tools:targetApi="m" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/pass_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginHorizontal="20dp"
                        android:onClick="passToggle"
                        android:src="@drawable/ic_baseline_visibility_24"
                        android:tint="@color/alcolor" />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginVertical="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/in_pc"
                        android:text="1234"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font3"
                        android:background="@drawable/edittext_outline"
                        android:drawableStart="@drawable/ic_lock_icon_01"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/alcolor"
                        android:hint="Pin"
                        android:inputType="numberPassword"
                        android:maxLength="4"
                        android:paddingHorizontal="30dp"
                        android:paddingVertical="12dp"
                        android:singleLine="true"
                        android:textColor="@color/alcolor"
                        android:textColorHint="@color/alcolor"
                        android:textCursorDrawable="@drawable/ic_cursor"
                        android:textStyle="bold"
                        tools:targetApi="m" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/pass_tpc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginHorizontal="20dp"
                        android:onClick="passTogglePin"
                        android:src="@drawable/ic_baseline_visibility_24"
                        android:tint="@color/alcolor" />

                </RelativeLayout>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/adarkg"
                android:onClick="signUp"
                android:paddingVertical="12dp"
                android:text="REGISTER"
                android:fontFamily="@font/font2"
                android:textAllCaps="false"
                android:textColor="@color/alcolor1"
                android:textSize="18sp"
                app:cornerRadius="30dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="30dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="0dp"
                    android:fontFamily="@font/font4"
                    android:text="@string/already_registered_signin"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:onClick="AlreadyRegistered" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="0dp"
                    android:visibility="gone"
                    android:fontFamily="@font/font4"
                    android:text="Have trouble login in?"
                    android:textSize="18sp"
                    android:textColor="@color/btnTextColor" />

                <LinearLayout
                    android:id="@+id/contact_us_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:visibility="visible"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/wp_icon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/whatsapp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:fontFamily="@font/font4"
                        android:padding="0dp"
                        android:text="Contact us"
                        android:textColor="@color/white"
                        android:textSize="18sp" />
                </LinearLayout>


            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:indeterminateTint="@color/editTextColor"
        android:visibility="gone" />

</RelativeLayout>
