<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="3dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <!-- Hidden views to satisfy old bindings in TurnamentListAdapter without visual layout footprint -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/chartTable"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- Left Content Column -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/eventStatusContainer"
            android:layout_alignParentStart="true"
            android:orientation="vertical">

            <!-- Market Name (e.g. SRIDEVI MORNING) -->
            <com.romainpiel.shimmer.ShimmerTextView
                android:id="@+id/eventType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font2"
                android:text="MARKET NAME"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold"
                app:reflectionColor="@color/black" />

            <!-- Result Number (e.g. ***-**-***) -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/eventNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font2"
                android:text="***_**_***"
                android:layout_marginTop="2dp"
                android:textColor="@color/brand_red"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Market Status (e.g. Closed for today) -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/marketOpen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font3"
                android:layout_marginTop="2dp"
                android:text="Closed for today"
                android:textColor="@color/brand_red"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Timing Columns Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Time Open column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/openlabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Bids"
                        android:textColor="#9E9E9E"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="1dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Open: "
                            android:textColor="@color/black"
                            android:textSize="11sp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/openingTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10:00 AM"
                            android:textColor="@color/black"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Time Close column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/closelabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Bids"
                        android:textColor="#9E9E9E"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="1dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Close: "
                            android:textColor="@color/black"
                            android:textSize="11sp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/closingTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11:00 AM"
                            android:textColor="@color/black"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Active Players Row (dynamically controlled) -->
            <LinearLayout
                android:id="@+id/activeUsersRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/circle_blue"
                    android:backgroundTint="#4CAF50"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvActiveUsers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1,024 Players Active"
                    android:textColor="#2E7D32"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Right Side: Circular status/play button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/eventStatusContainer"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="@color/brand_red"
            app:strokeWidth="2dp"
            app:cardElevation="0dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/eventStatus"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/play_icon"
                app:tint="@color/brand_red" />
        </com.google.android.material.card.MaterialCardView>

    </RelativeLayout>
</androidx.cardview.widget.CardView>