<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    android:id="@+id/drawerLayout"
    tools:context=".sfdghj.DashboardActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/status_bar_height"
            android:background="@color/white"
            android:id="@+id/appbarLayout">

                <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/white"
                android:contentInsetStart="0dp"
                app:contentInsetLeft="0dp"
                app:contentInsetStart="0dp"
                app:contentInsetStartWithNavigation="0dp"
                app:popupTheme="@style/MyDarkToolbarStyle">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Left: Menu Button -->
                    <ImageView
                        android:id="@+id/menu_button"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_baseline_menu_24"
                        app:tint="@color/brand_red"
                        android:clickable="true"
                        android:focusable="true"/>

                    <!-- Logo and App Name -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_toEndOf="@id/menu_button"
                        android:layout_marginStart="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@mipmap/ic_launcher_round" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textColor="@color/brand_purple"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/font2"/>
                    </LinearLayout>

                    <!-- Right Section: Wallet Text, Wallet Button, Notification Button -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_alignParentEnd="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginEnd="16dp">

                        <!-- Wallet Balance Text -->
                        <TextView
                            android:id="@+id/wallet_balance_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹ 0"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:layout_marginEnd="10dp"/>

                        <!-- Wallet Action Button -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/wallet_pill"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="10dp"
                            app:cardBackgroundColor="@color/brand_red"
                            app:cardElevation="2dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginEnd="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_wallet"
                                android:layout_gravity="center"
                                app:tint="@color/white"/>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Notification Action Button -->
                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/notification_button_card"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                app:cardCornerRadius="18dp"
                                app:cardBackgroundColor="@color/brand_red"
                                app:cardElevation="2dp"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:id="@+id/notification_icon"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_notification_white"
                                    android:layout_gravity="center"
                                    app:tint="@color/white" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/notification_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="16dp"
                                android:text="0"
                                android:gravity="center"
                                android:visibility="gone"
                                android:textColor="@color/white"
                                android:textSize="9sp"
                                android:background="@drawable/badge_bg_black"
                                android:paddingHorizontal="4dp"
                                android:layout_alignParentTop="true"
                                android:layout_alignStart="@id/notification_button_card"
                                android:layout_marginStart="24dp"
                                android:layout_marginTop="-4dp" />
                        </RelativeLayout>

                    </LinearLayout>

                </RelativeLayout>

            </com.google.android.material.appbar.MaterialToolbar>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/main_gradient_background"
                app:tabGravity="fill"
                app:tabSelectedTextColor="@color/white"
                android:paddingTop="5dp"
                app:tabBackground="@drawable/tab_color_selector"
                android:visibility="gone"
                app:tabMode="fixed" />

        </com.google.android.material.appbar.AppBarLayout>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/dataConText"
            android:text="@string/you_are_not_connected_to_internet"
            android:textColor="@color/white"
            android:background="@color/warn_red"
            android:padding="5dp"
            android:layout_below="@id/appbarLayout"
            android:elevation="1dp"
            android:visibility="gone"/>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@color/white"
            android:elevation="8dp"
            app:itemIconTint="@color/bottom_nav_color"
            app:itemTextColor="@color/bottom_nav_color"
            android:visibility="visible"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_bottom_nav" />

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_ref_lyt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/dataConText"
            android:layout_above="@id/bottom_navigation">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.onegamematkafun.market.adapterclass.NonSwipeableViewPager
                    android:id="@+id/viewPager"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_behavior="@string/appbar_scrolling_view_behavior" />

                <!-- Original ProgressBar -->
                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:id="@+id/progressBar"
                    android:visibility="gone"
                    android:indeterminateTint="@color/primary_color" />

            </RelativeLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>



    </RelativeLayout>




    <RelativeLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone"
        android:gravity="center">

        <!-- Large Spinner -->
        <ProgressBar
            android:id="@+id/fullScreenProgressBar"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/primary_color" />
    </RelativeLayout>

    <!-- NavigationView for the drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu_drawer"
        app:itemTextColor="@color/black"
        app:itemIconTint="@color/nav_icon_tint"
        app:itemBackground="@drawable/nav_item_bg"
        android:background="@drawable/bg_nav_drawer"
        app:theme="@style/NavigationDrawerStyle"
        app:headerLayout="@layout/drawer_header" />

</androidx.drawerlayout.widget.DrawerLayout>
