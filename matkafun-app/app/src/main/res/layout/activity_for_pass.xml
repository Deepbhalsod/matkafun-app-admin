<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adarkg"
    android:orientation="vertical"
    tools:context=".sfdghj.ForPassActivity">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/dataConText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/you_are_not_connected_to_internet"
        android:textColor="@color/white"
        android:background="@color/warn_red"
        android:padding="5dp"
        android:visibility="gone"
        android:elevation="1dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/imageview1"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginBottom="15dp"
            android:src="@drawable/loginslogo"
            android:scaleType="fitCenter" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/text_forgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginBottom="15dp"
            android:layout_marginHorizontal="0dp"
            android:layout_marginTop="1dp"
            android:text="@string/forgot_pass"
            android:fontFamily="@font/font2"
            android:textColor="@color/alightg"
            android:textSize="13sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/phone_num"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:fontFamily="@font/font3"
            android:background="@drawable/edittext_outline"
            android:drawableStart="@drawable/baseline_phone_iphone_24"
            android:drawablePadding="12dp"
            android:drawableTint="@color/alightg"
            android:hint="Phone"
            android:inputType="number"
            android:maxLength="10"
            android:paddingHorizontal="30dp"
            android:paddingVertical="12dp"
            android:singleLine="true"
            android:textColor="@color/alcolor"
            android:textColorHint="@color/alcolor"
            android:textCursorDrawable="@drawable/ic_cursor"
            android:textStyle="bold"
            tools:targetApi="m" />

        <com.google.android.material.button.MaterialButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/alightg"
            android:onClick="sendOTP"
            android:paddingVertical="12dp"
            android:text="GO"
            android:fontFamily="@font/font2"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/backLoginText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="30dp"
            android:layout_gravity="right"
            android:padding="0dp"
            android:fontFamily="@font/font4"
            android:text="Back to LOG IN"
            android:textSize="15sp"
            android:textColor="@color/alightg"
            android:onClick="backToLogin" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:indeterminateTint="@color/golden"
        android:visibility="gone" />

</RelativeLayout>
