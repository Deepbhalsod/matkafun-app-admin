<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/adarkg"
    tools:context=".dfghjk.StarlineFragment">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardElevation="10dp"
        app:cardCornerRadius="20dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical"
            android:background="@drawable/buttonw">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/singleD"
                android:layout_width="wrap_content"
                android:fontFamily="@font/font2"
                android:layout_height="wrap_content"
                android:text="SINGLE DIGIT"
                android:textColor="@color/white"

                android:textStyle="bold"/>
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/single_d_v"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font2"
                android:textColor="@color/white"
                android:layout_alignParentEnd="true"
                android:textStyle="bold"/>
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/single_p"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font2"
                android:text="SINGLE PANNA"
                android:textColor="@color/white"
                android:layout_below="@id/singleD"
                android:textStyle="bold"
                android:layout_marginVertical="8dp"/>
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/single_p_v"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:layout_below="@id/singleD"
                android:fontFamily="@font/font2"
                android:layout_alignParentEnd="true"
                android:textStyle="bold"
                android:layout_marginVertical="8dp"/>
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/doP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DOUBLE PANNA"
                android:textColor="@color/white"
                android:fontFamily="@font/font2"
                android:layout_below="@id/single_p"
                android:textStyle="bold"/>
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/double_p_v"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:layout_below="@id/single_p"
                android:fontFamily="@font/font2"
                android:layout_alignParentEnd="true"
                android:textStyle="bold"/>
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/TriplePana"
                android:layout_width="wrap_content"
                android:fontFamily="@font/font2"
                android:layout_height="wrap_content"
                android:text="TRIPLE PANNA"
                android:textColor="@color/white"
                android:layout_below="@id/doP"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/triple_p_v"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:layout_below="@id/doP"
                android:fontFamily="@font/font2"
                android:layout_alignParentEnd="true"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/chartTableBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/triple_p_v"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:backgroundTint="@color/adarkg"
                android:text="@string/chart"
                android:textColor="@color/alcolor1" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp">

        <TextView
            android:id="@+id/bHisBtn"
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:layout_alignParentStart="true"
            android:background="@drawable/button"
            android:backgroundTint="@color/alightg"
            android:gravity="center"
            android:text="BID HISTORY"
            android:fontFamily="@font/font2"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/wHisBtn"
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/button"
            android:backgroundTint="@color/alightg"
            android:gravity="center"
            android:text="WIN HISTORY"
            android:textColor="@color/white"
            android:fontFamily="@font/font2"
            tools:ignore="RelativeOverlap" />

    </RelativeLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/recy_s_l"
        tools:listitem="@layout/s_l_turnament_layout"/>

</LinearLayout>