<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/adarkg"
    android:fitsSystemWindows="true"
    tools:context=".sfdghj.DesawarBPActivity">
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/status_bar_height"
        android:id="@+id/appbarLayout">
        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/tool_bar"
            android:background="@color/alightg"
            app:navigationIconTint="@color/white"
            app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
            app:titleTextColor="@color/white"
            app:contentInsetStartWithNavigation="0dp"/>
    </com.google.android.material.appbar.AppBarLayout>
    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/internet_text"
        android:text="@string/you_are_not_connected_to_internet"
        android:textColor="@color/white"
        android:background="@color/warn_red"
        android:padding="5dp"
        android:visibility="gone"
        android:elevation="1dp"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/adarkg">
        <LinearLayout
            android:id="@+id/ll_bid"
            android:layout_alignParentTop="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/adarkg">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/choose_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/buttonwb"
                android:padding="10dp"
                android:fontFamily="@font/font3"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="20dp"
                android:textSize="16sp"
                android:textColor="@color/alcolor1"/>


            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/input_d"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/buttonwb"
                android:hint="@string/enter_digits"
                android:layout_marginTop="10dp"
                android:padding="10dp"
                android:textColorHint="@color/alcolor1"
                android:fontFamily="@font/font3"
                android:textColor="@color/alcolor1"
                android:inputType="number"
                android:layout_marginHorizontal="20dp"/>

            <LinearLayout
                android:id="@+id/llJodiSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvJodiSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>


            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/openCD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/digits"
                android:textStyle="bold"
                android:paddingVertical="10dp"
                android:textColor="@color/btnTextColor"
                android:textSize="18sp"
                android:layout_marginTop="5dp"
                android:layout_marginHorizontal="20dp"
                android:visibility="gone"/>
            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/inputCD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/buttonwb"
                android:hint="@string/enter_digits"
                android:padding="10dp"
                android:textColor="@color/alcolor1"
                android:inputType="number"
                android:textColorHint="@color/alcolor1"
                android:layout_marginHorizontal="20dp"
                android:visibility="gone"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_text_coins"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/buttonwb"
                android:hint="@string/enter_points"
                android:padding="10dp"
                android:textColorHint="@color/alcolor1"
                android:inputType="number"
                android:layout_marginTop="10dp"
                android:maxLength="9"
                android:fontFamily="@font/font3"
                android:textColor="@color/alcolor1"
                android:layout_marginHorizontal="20dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_proceed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/proceed"
                android:layout_centerInParent="true"
                android:backgroundTint="@color/primary_color"
                app:cornerRadius="20dp"
                android:textColor="@color/white"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="20dp"
                android:fontFamily="@font/font2"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:layout_below="@+id/ll_bid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            tools:listitem="@layout/s_l_playing_layout"
            android:layout_marginBottom="10dp"
            android:layout_above="@id/ll_bid_bottom"
            android:id="@+id/recyclerView"/>
        <LinearLayout
            android:id="@+id/ll_bid_bottom"
            android:layout_alignParentBottom="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:orientation="horizontal"
            android:visibility="gone">
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/mtv_total_coins"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:layout_height="match_parent"
                android:textColor="@color/btnTextColor"
                android:textStyle="bold"
                android:text="Total Points : 0"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/pro_conf"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:backgroundTint="@color/alightg"
                android:fontFamily="@font/font2"
                android:text="@string/proceed"
                android:textColor="@color/black"
                android:gravity="center"
                android:onClick="proceedConformBtn"/>
        </LinearLayout>
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:id="@+id/progress_bar"
            android:visibility="gone"/>
    </RelativeLayout>
</LinearLayout>