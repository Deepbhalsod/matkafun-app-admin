<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginHorizontal="12dp"
    app:cardBackgroundColor="#171A30"
    app:strokeColor="#2F365D"
    app:strokeWidth="1dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/circleBg"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#00A896">
            
            <TextView
                android:id="@+id/tvAvatarLetter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:text="6"/>
                
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/llMiddle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/circleBg"
            android:layout_toStartOf="@id/llRight"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWinnerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="******6952"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvGameDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GHAZIABAD • Jodi"
                android:textColor="#8F94AC"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="end">

            <TextView
                android:id="@+id/tvWinAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹66,800"
                android:textColor="#00E676"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Won"
                android:textColor="#8F94AC"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
