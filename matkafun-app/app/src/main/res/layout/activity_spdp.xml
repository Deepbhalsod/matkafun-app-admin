<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/adarkg"
    tools:context=".activityclass.SPDPActivity">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/dataConText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/you_are_not_connected_to_internet"
        android:textColor="@color/white"
        android:background="@color/warn_red"
        android:padding="5dp"
        android:visibility="gone"
        android:elevation="1dp" />

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:paddingTop="@dimen/status_bar_height"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/alightg"
            app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
            app:title="MILAN DAY, sp/dp/tp"
            app:titleTextColor="@color/white"
            app:menu="@menu/menu_purse" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="0dp">

            <LinearLayout
                android:id="@+id/llDateSession"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="20dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_choose_session"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/font3"
                    android:background="@drawable/buttonwb"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:textColor="@color/alcolor1" />

                <Spinner
                    android:id="@+id/spinnerSession"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/buttonwb" />
                
                <RadioGroup
                    android:id="@+id/radioGroup"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone">
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/open"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="open" />
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/close"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="close" />
                </RadioGroup>
            </LinearLayout>

            <!-- CheckBoxes for SP / DP / TP -->
            <LinearLayout
                android:id="@+id/llSpDpTp"
                android:layout_width="match_parent"
                android:layout_marginTop="10dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:padding="6dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/buttonwb">
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbSp"
                    android:layout_width="0dp"
                    android:fontFamily="@font/font3"
                    android:layout_height="wrap_content"
                    android:text="SP"
                    android:textColor="@color/alcolor1"
                    android:layout_weight="1"/>
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbDp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font3"
                    android:text="DP"
                    android:textColor="@color/alcolor1"
                    android:layout_weight="1"/>
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbTp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font3"
                    android:text="TP"
                    android:textColor="@color/alcolor1"
                    android:layout_weight="1"/>
            </LinearLayout>

            <!-- Digit Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="20dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Enter Digit:"
                    android:textColor="@color/btnTextColor"
                    android:textSize="16sp" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_digit"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/font3"
                    android:background="@drawable/buttonwb"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/alcolor1"
                    android:textSize="16sp"
                    android:inputType="number" />
            </LinearLayout>

            <!-- Points Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="20dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="Enter Points:"
                    android:textColor="@color/btnTextColor"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_points"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/buttonwb"
                        android:hint="Points"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:inputType="number"
                        android:textColorHint="#9e9e9e"
                        android:fontFamily="@font/font3"
                        android:maxLength="9"
                        android:textColor="@color/alcolor1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_proceed"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:text="Add"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:fontFamily="@font/font2"
                        android:backgroundTint="@color/primary_color"
                        app:cornerRadius="25dp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_preview_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                android:orientation="vertical"
                android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:background="@color/primary_color"
                        android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Digits"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Points"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Type"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:gravity="center"
                        android:text="Delete"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:listitem="@layout/item_bulk_bid_preview" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Summary Bar -->
    <LinearLayout
        android:id="@+id/ll_bid_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="@color/adarkg"
        android:visibility="visible"
        android:elevation="4dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_total_points"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Total Points : 0"
            android:textStyle="bold"
            android:fontFamily="@font/font3"
            android:textColor="@color/btnTextColor"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_full_submit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Submit"
            android:backgroundTint="@color/alightg"
            android:textColor="@color/white"
            app:cornerRadius="16dp" />
    </LinearLayout>

</LinearLayout>
