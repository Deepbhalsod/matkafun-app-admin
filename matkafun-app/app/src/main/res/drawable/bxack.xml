<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background image with fixed height -->
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <bitmap
            android:src="@drawable/imageback"
            android:gravity="fill" />
    </item>

    <!-- Rounded corners and optional stroke -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <stroke
                android:width="2dp"
                android:color="@color/alightg" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
