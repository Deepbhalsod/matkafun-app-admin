<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected Tab -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/alightg"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1dp" android:color="@color/alightg"/>
        </shape>
    </item>

    <!-- Unselected Tab -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/matka_ic_grey"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1dp" android:color="@color/matka_darkblue"/>
        </shape>
    </item>
</selector>
